# Environment variables required by the app on Railway.
# Set these in the Railway service (Variables tab) or via scripts/railway-set-env.sh.
# Do NOT commit real values. NEXT_PUBLIC_* are inlined at BUILD time.
# Do NOT set PORT — Railway injects it and `next start` reads it automatically.

# --- Supabase (DB + Auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI (customer analyze, call summary, extraction) ---
OPENAI_API_KEY=
KIMI_API_KEY=

# --- dtac OneCall / Oreka talk-time API (outbound) ---
OREKA_BASE_URL=
OREKA_USER=
OREKA_PASSWORD=
OREKA_HOPEFUL_USER=
OREKA_HOPEFUL_PASSWORD=

# --- App ---
SUPERVISOR_INVITE_CODE=
